#!/bin/bash
SCRIPT_DIR="$(cd "$(dirname "$0")/../../.." && pwd)"

# Find Python 3 with PyObjC installed
# Try Homebrew python3 first (any version), then system python3
PYTHON=""
for candidate in /opt/homebrew/bin/python3 /usr/local/bin/python3 "$(which python3 2>/dev/null)"; do
    if [ -x "$candidate" ] && "$candidate" -c "import AppKit" 2>/dev/null; then
        PYTHON="$candidate"
        break
    fi
done

if [ -z "$PYTHON" ]; then
    osascript -e 'display alert "Say the word..." message "Python 3 with PyObjC is required.\n\nRun: pip3 install pyobjc-framework-Cocoa pyobjc-framework-Quartz" as critical'
    exit 1
fi

# Kill existing instance — match exact script path to avoid killing unrelated processes
pgrep -f "python3.*${SCRIPT_DIR}/voice_app\\.py" | xargs kill 2>/dev/null
sleep 0.3

exec "$PYTHON" "$SCRIPT_DIR/voice_app.py"
