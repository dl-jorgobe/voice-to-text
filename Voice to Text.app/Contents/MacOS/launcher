#!/bin/bash
SCRIPT_DIR="$(cd "$(dirname "$0")/../../.." && pwd)"

# Use Homebrew Python 3.12 (has PyObjC installed)
PYTHON="/opt/homebrew/Cellar/python@3.12/3.12.13/Frameworks/Python.framework/Versions/3.12/bin/python3.12"

# Fallback to system python3 if homebrew not found
if [ ! -x "$PYTHON" ]; then
    PYTHON="$(which python3)"
fi

pgrep -f "python3.*voice_app" | xargs kill 2>/dev/null
sleep 0.3

exec "$PYTHON" "$SCRIPT_DIR/voice_app.py"
